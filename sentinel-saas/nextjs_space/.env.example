# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db
# Production: postgresql://user:password@host:5432/dbname

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-long-random-secret-here
NEXTAUTH_URL=http://localhost:4000
# Production: https://your-domain.com

# ── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=64-char-hex-string-here

# ── Bot Orchestrator (Python engine) ─────────────────────────────────────────
# Production: set this to the internal URL of your Python engine service
ORCHESTRATOR_URL=http://localhost:5000

# ── Notifications (AbacusAI / app notifications) ──────────────────────────────
ABACUSAI_API_KEY=
WEB_APP_ID=
NOTIF_ID_NEW_USER_SIGNUP=
NOTIF_ID_SUBSCRIPTION_CHANGE=

# ── Admin / Payments ──────────────────────────────────────────────────────────
# Email address that receives payment confirmation notifications
ADMIN_EMAIL=admin@your-domain.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
