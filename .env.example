# ── Exchange: CoinDCX (live trading) ─────────────────────────────────────────
COINDCX_API_KEY=your_coindcx_api_key_here
COINDCX_API_SECRET=your_coindcx_api_secret_here

# ── Exchange: Binance (paper trading / data fallback) ─────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to run in paper trade mode (no real orders placed)
PAPER_TRADE=true
# Set to "true" to use Binance Testnet instead of production
TESTNET=false

# ── Telegram Notifications (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Sentiment Engine (optional) ───────────────────────────────────────────────
# Set to "true" to enable sentiment scoring (adds 18 pts to conviction score)
SENTIMENT_ENABLED=false
# CryptoPanic free API key: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=
# Reddit app credentials: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=hmmbot/1.0

# ── SaaS / Dashboard (only needed for saas_engine/) ──────────────────────────
DATABASE_URL=
